    "@vendia/serverless-express": "^4.12.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.39",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"

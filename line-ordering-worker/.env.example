# ─────────────────────────────────────────────────────────
# LINE Ordering Worker — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────

NODE_ENV=production

# ── LINE Messaging API ────────────────────────────────────
# LINE Developers Console → your channel → Messaging API tab
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_access_token_here

# ── Admin notification target ─────────────────────────────
# Use LINE_ADMIN_GROUP_ID if notifying a group (preferred)
# Use LINE_ADMIN_USER_ID to notify a single admin user
LINE_ADMIN_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_ADMIN_GROUP_ID=

# ── Security ──────────────────────────────────────────────
# Random string shared between backend and this worker
# Generate: openssl rand -hex 32
WORKER_SECRET=change_me_to_a_random_secret

# ── URLs ──────────────────────────────────────────────────
BACKEND_URL=https://zmwvrrn6td.execute-api.ap-southeast-1.amazonaws.com
ALLOWED_ORIGIN=https://line-ordering-frontend.vercel.app

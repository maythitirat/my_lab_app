# ─────────────────────────────────────────────────────────────
# LINE LIFF — Frontend Environment Variables
# Copy this file to .env.local and fill in the real values.
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────

# LINE LIFF ID (from LINE Developers Console → LIFF tab)
# Format: 1234567890-AbCdEfGh
NEXT_PUBLIC_LIFF_ID=your-liff-id-here

# Backend API base URL (no trailing slash)
# Local dev  : http://localhost:3001
# Production : https://<api-id>.execute-api.<region>.amazonaws.com/prod
NEXT_PUBLIC_API_URL=http://localhost:3001

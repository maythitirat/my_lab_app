# ─────────────────────────────────────────────────────────────
# LINE Ordering — Backend Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# ── Option A: Supabase / any PaaS (recommended for production) ──────────────
# Supabase: Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL (port 6543) for serverless / Lambda
# DATABASE_URL=postgresql://postgres.XXXX:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.leuicqbzyzeqggfgfvmm:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ── Option B: Local PostgreSQL (used when DATABASE_URL is unset) ────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=line_liff_ordering

# ── CORS — your Vercel frontend URL (no trailing slash) ──────────────────────
ALLOWED_ORIGIN=https://line-ordering-frontend.vercel.app
# Production example:
# ALLOWED_ORIGIN=https://line-ordering.vercel.app

# ── Worker (LINE Messaging) ───────────────────────────────────────────────────
# URL of the deployed line-ordering-worker Lambda
WORKER_URL=https://your-worker-id.execute-api.ap-southeast-1.amazonaws.com
# Must match WORKER_SECRET in line-ordering-worker .env
WORKER_SECRET=change_me_to_a_random_secret
